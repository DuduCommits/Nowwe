{
  "name": "balanceboard",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n \"server,client\" -c \"yellow,cyan\" \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cd server && node --watch index.js",
    "dev:client": "cd client && bun run dev",
    "build": "cd client && npm install && npm run build",
    "start": "cd server && node index.js",
    "install:all": "cd server && bun install && cd ../client && bun install"
  },
  "dependencies": {},
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
